# === Supabase PostgreSQL ===
SUPABASE_DB_URL=jdbc:postgresql://aws-1-eu-west-2.pooler.supabase.com:5432/postgres
SUPABASE_DB_USER=postgres.your-project-ref
SUPABASE_DB_PASSWORD=your-supabase-password

# === WhatsApp ===
WHATSAPP_PROVIDER=gowa
WHATSAPP_VERIFY_TOKEN=kolo-verify-token

# WhatsApp Web via GOWA
GOWA_BASE_URL=http://whatsapp-go:3000
GOWA_USERNAME=kolo-admin
GOWA_PASSWORD=change-this-gowa-password
GOWA_DEVICE_ID=
GOWA_WEBHOOK_SECRET=change-this-gowa-webhook-secret

# Optional legacy WhatsApp Cloud API fallback
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_URL=https://graph.facebook.com/v21.0

# === OpenRouter AI ===
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# === App Security ===
APP_API_KEY=change-this-api-key
